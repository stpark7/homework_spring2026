{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug DQN CartPole",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/src/scripts/run_dqn.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "python": "${workspaceFolder}/.venv/bin/python",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src"
      },
      "args": [
        "-cfg",
        "${workspaceFolder}/experiments/dqn/cartpole.yaml",
        "--eval_interval",
        "2500"
      ]
    }
  ]
}
